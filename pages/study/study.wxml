<view class="study-page" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">

  <!-- 动画层：切换时整体淡入淡出；panels 不参与动画 -->
  <view class="slide-content {{slideAnimClass}}">

    <!-- 视频层：wx:if 确保切换时彻底销毁旧组件，避免旧尾帧被新比例拉伸 -->
    <video
      wx:if="{{videoVisible}}"
      id="mainVideo"
      class="video-player {{currentVideo.videoOrientation === 'portrait' ? 'video-player-portrait' : 'video-player-landscape'}}"
      src="{{currentVideo.videoUrl}}"
      controls="{{false}}"
      show-progress="{{false}}"
      show-play-btn="{{false}}"
      show-center-play-btn="{{false}}"
      show-fullscreen-btn="{{false}}"
      autoplay="{{true}}"
      object-fit="contain"
      bindended="onVideoEnded"
      bindplay="onVideoPlay"
      bindcanplay="onVideoCanPlay"
      bindloadedmetadata="onVideoLoaded"
    ></video>

    <!-- 切换过渡遮罩：switchMaskFading=true 时渐入，false 时渐出 -->
    <view class="switch-mask {{switchMaskFading ? 'switch-mask-active' : ''}}"></view>

    <!-- 视频点击区域（暂停/播放） -->
    <view class="video-tap-area" bindtap="toggleVideoPlay">
      <view wx:if="{{!isPlaying}}" class="pause-indicator">
        <text class="pause-icon">▶</text>
      </view>
    </view>

    <!-- 顶部 + 底部渐变蒙层 -->
    <view class="video-mask"></view>

    <!-- 顶部浮层：返回 -->
    <view class="top-bar">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
    </view>

    <!-- 右侧悬浮学习按钮栏 -->
    <view wx:if="{{!showQuestionDrawer && !glossaryVisible}}" class="action-bar">
      <view class="action-item action-item-cta" bindtap="openQuestionDrawer">
        <view class="action-circle action-circle-cta">
          <text class="action-glyph">?</text>
        </view>
        <text class="action-caption">答题</text>
      </view>

      <view class="action-item {{subtitleVisible ? 'is-active' : ''}}" bindtap="toggleSubtitle">
        <view class="action-circle">
          <text class="action-glyph">字</text>
        </view>
        <text class="action-caption">字幕</text>
      </view>

      <view class="action-item {{glossaryVisible ? 'is-active' : ''}}" bindtap="openGlossary">
        <view class="action-circle">
          <text class="action-glyph">词</text>
        </view>
        <text class="action-caption">词汇</text>
      </view>
    </view>

    <!-- 底部信息浮层 -->
    <view wx:if="{{!showQuestionDrawer}}" class="bottom-info">
      <view class="meta-row">
        <text class="tag scene-tag">{{currentVideo.sceneName}}</text>
        <text class="tag level-tag">{{currentVideo.level}}</text>
      </view>
      <text class="bottom-title">{{currentVideo.title}}</text>

      <view wx:if="{{subtitleVisible}}" class="subtitle-overlay">
        <view wx:if="{{currentVideo.subtitleLines && currentVideo.subtitleLines.length > 0}}">
          <block wx:for="{{currentVideo.subtitleLines}}" wx:key="index">
            <text class="subtitle-line">{{item}}</text>
          </block>
        </view>
        <text wx:else class="subtitle-line">{{currentVideo.subtitle}}</text>
      </view>
    </view>
  </view>

  <!-- 词汇底部抽屉（不参与切换动画） -->
  <view wx:if="{{glossaryVisible || glossaryClosing}}" class="panel-backdrop {{glossaryClosing ? 'backdrop-closing' : ''}}" bindtap="closeGlossary"></view>
  <view wx:if="{{glossaryVisible || glossaryClosing}}" class="panel glossary-panel {{glossaryClosing ? 'panel-closing' : ''}}">
    <view class="panel-handle"></view>
    <view class="panel-header">
      <text class="panel-title">词汇释义</text>
      <view class="hint-toggle {{showChineseHint ? 'is-on' : ''}}" catchtap="toggleChineseHint">
        <text class="hint-toggle-text">
          {{showChineseHint ? '隐藏中文' : '显示中文'}}
        </text>
      </view>
    </view>

    <scroll-view class="glossary-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <block wx:for="{{currentVideo.glossary}}" wx:key="word">
        <view class="glossary-item">
          <text class="word">{{item.word}}</text>
          <text class="meaning">{{item.meaning}}</text>
          <text wx:if="{{showChineseHint}}" class="chinese-hint">
            中文提示：{{item.chineseHint}}
          </text>
        </view>
      </block>
    </scroll-view>
  </view>

  <!-- 答题底部抽屉（不参与切换动画） -->
  <view wx:if="{{showQuestionDrawer || questionDrawerClosing}}" class="panel-backdrop {{questionDrawerClosing ? 'backdrop-closing' : ''}}" bindtap="closeQuestionDrawer"></view>
  <view wx:if="{{showQuestionDrawer || questionDrawerClosing}}" class="panel question-panel {{questionDrawerClosing ? 'panel-closing' : ''}}">
    <view class="panel-handle"></view>
    <view class="panel-header">
      <text class="panel-title {{answerSubmitted ? (isCorrect ? 'result-title-correct' : 'result-title-wrong') : ''}}">
        {{answerSubmitted ? answerFeedbackText : '理解题'}}
      </text>
      <text class="panel-tag">{{currentIndex + 1}} / {{totalVideos}}</text>
    </view>

    <!-- 答题阶段 -->
    <block wx:if="{{!answerSubmitted}}">
      <scroll-view class="question-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <text class="question-text">{{currentVideo.question.text}}</text>
        <view class="option-list">
          <block wx:for="{{currentVideo.question.options}}" wx:key="index">
            <view
              class="option {{selectedIndex == index ? 'active' : ''}}"
              data-index="{{index}}"
              bindtap="chooseOption"
            >
              <text class="option-index">{{index === 0 ? 'A' : index === 1 ? 'B' : index === 2 ? 'C' : 'D'}}</text>
              <text class="option-text">{{item}}</text>
            </view>
          </block>
        </view>
      </scroll-view>
      <view class="panel-footer">
        <button class="primary-btn" bindtap="submitAnswer">提交答案</button>
        <view class="replay-row" bindtap="replayVideo">
          <text class="replay-text">重播视频</text>
        </view>
      </view>
    </block>

    <!-- 结果阶段 -->
    <block wx:else>
      <scroll-view class="question-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="feedback-panel">

          <!-- 题目 -->
          <view class="feedback-section">
            <text class="feedback-section-label">题目</text>
            <text class="feedback-question-text">{{currentVideo.question.text}}</text>
          </view>

          <!-- 正确答案 -->
          <view class="feedback-section">
            <text class="feedback-section-label">正确答案</text>
            <view class="feedback-answer-card">
              <view class="feedback-answer-badge"><text class="feedback-answer-badge-text">{{currentVideo.question.answerIndex === 0 ? 'A' : currentVideo.question.answerIndex === 1 ? 'B' : currentVideo.question.answerIndex === 2 ? 'C' : 'D'}}</text></view>
              <text class="feedback-answer-text">{{currentVideo.question.options[currentVideo.question.answerIndex]}}</text>
            </view>
          </view>

          <!-- 解释 -->
          <view wx:if="{{answerExplanation}}" class="feedback-section">
            <text class="feedback-section-label">解释</text>
            <view class="feedback-explanation-card">
              <text class="feedback-explanation-text">{{answerExplanation}}</text>
            </view>
          </view>

        </view>
      </scroll-view>
      <view class="panel-footer">
        <button class="primary-btn feedback-continue-btn {{isCorrect ? '' : 'primary-btn-next'}}" bindtap="goNextFromResult">继续下一条</button>
      </view>
    </block>

  </view>

</view>
