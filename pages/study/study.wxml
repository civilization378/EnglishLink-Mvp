<view class="container">
  <view class="header">
    <text class="title">{{currentVideo.title}}</text>

    <view class="tag-row">
      <text class="tag">{{currentVideo.sceneName}}</text>
      <text class="tag level-tag">{{currentVideo.level}}</text>
    </view>
  </view>

  <view class="video-card">
    <video
      class="video-player"
      src="{{currentVideo.videoUrl}}"
      controls
      autoplay="{{false}}"
      object-fit="cover"
    ></video>
  </view>

  <view class="section subtitle-card">
    <text class="section-title">字幕</text>
    <view wx:if="{{currentVideo.subtitleLines && currentVideo.subtitleLines.length > 0}}">
      <block wx:for="{{currentVideo.subtitleLines}}" wx:key="index">
        <text class="subtitle-line">{{item}}</text>
      </block>
    </view>
    <text wx:else class="subtitle">{{currentVideo.subtitle}}</text>
  </view>

<view class="section">
  <view class="section-header">
    <text class="section-title">词汇释义</text>
    <text class="hint-toggle" bindtap="toggleChineseHint">
      {{showChineseHint ? '隐藏中文提示' : '显示中文提示'}}
    </text>
  </view>

  <block wx:for="{{currentVideo.glossary}}" wx:key="word">
    <view class="glossary-item">
      <text class="word">{{item.word}}</text>
      <text class="meaning">{{item.meaning}}</text>

      <text wx:if="{{showChineseHint}}" class="chinese-hint">
        中文提示：{{item.chineseHint}}
      </text>
    </view>
  </block>
</view>

  <view class="section">
    <text class="section-title">理解题</text>
    <text class="question">{{currentVideo.question.text}}</text>

    <block wx:for="{{currentVideo.question.options}}" wx:key="index">
      <view 
        class="option {{selectedIndex == index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="chooseOption"
      >
        {{item}}
      </view>
    </block>
  </view>

  <button bindtap="submitAnswer">提交答案</button>

  <text class="result">{{resultText}}</text>
</view>