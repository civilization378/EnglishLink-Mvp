.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #222;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tag-row {
  display: flex;
  gap: 16rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  color: #3b64c4;
  font-size: 24rpx;
}

.level-tag {
  background: #f0f9f2;
  color: #29994f;
}


.video-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.video-player {
  width: 100%;
  border-radius: 12rpx;
  background: #000;
}

.video-player-landscape {
  height: 380rpx;
}

.video-player-portrait {
  height: 720rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #444;
  line-height: 1.6;
}

.subtitle-card {
  background: #f7fbff;
  border: 1rpx solid #dbe9ff;
}

.subtitle-line {
  display: block;
  font-size: 30rpx;
  color: #2f3f57;
  line-height: 1.7;
  margin-bottom: 10rpx;
}

.subtitle-line:last-child {
  margin-bottom: 0;
}

.section {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}

.glossary-item {
  margin-bottom: 12rpx;
}

.word {
  font-weight: bold;
  margin-right: 16rpx;
}

.meaning {
  color: #666;
}

.question {
  margin-bottom: 20rpx;
  display: block;
  color: #333;
}

.option {
  padding: 20rpx;
  background: #f2f4f7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.option.active {
  background: #dfefff;
  border: 2rpx solid #4a90e2;
}

.result {
  font-size: 28rpx;
  color: #2c7;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.hint-toggle {
  font-size: 24rpx;
  color: #3b64c4;
}

.glossary-item {
  margin-bottom: 20rpx;
}

.word {
  display: block;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.meaning {
  display: block;
  color: #666;
  margin-bottom: 6rpx;
}

.chinese-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.video-hint {
  padding: 20rpx 0;
  display: flex;
  justify-content: center;
}

.video-hint-text {
  font-size: 26rpx;
  color: #6B7280;
}

.question-stage {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.fade-in {
  animation: fadeInUp 360ms ease-out both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}