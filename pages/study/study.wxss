page {
  background: #020617;
}

/* ============ 根容器：全屏沉浸式 ============ */
.study-page {
  position: fixed;
  inset: 0;
  background: #020617;
  overflow: hidden;
  color: #FFFFFF;
}

/* ============ 动画内容层（包裹视频和浮层，panels 不在其内） ============ */
.slide-content {
  position: absolute;
  inset: 0;
  transition:
    opacity 240ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

.switching-next-out {
  opacity: 0;
  transform: translateY(-18rpx);
}

.switching-next-in {
  animation: slideInFromBottom 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.switching-prev-out {
  opacity: 0;
  transform: translateY(18rpx);
}

.switching-prev-in {
  animation: slideInFromTop 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes slideInFromBottom {
  from { opacity: 0; transform: translateY(18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideInFromTop {
  from { opacity: 0; transform: translateY(-18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ============ 视频层（铺满整屏） ============ */
.video-player {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: #000;
  z-index: 0;
}

/* 横/竖屏共用全屏容器，object-fit: contain 自然处理两种比例 */
.video-player-landscape,
.video-player-portrait {
  /* 视觉上仅作占位标识，避免误删；实际尺寸由父级 100% 控制 */
}

/* 切换过渡遮罩：始终在 DOM 中，双向 opacity 过渡，防旧帧抽搐 */
.switch-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(2, 6, 23, 0.75), rgba(2, 6, 23, 0.55));
  z-index: 1;
  pointer-events: none;
  opacity: 0;
  transition: opacity 200ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* 遮罩激活态：渐入到 0.65，不完全纯黑，保留画面层次感 */
.switch-mask-active {
  opacity: 0.65;
}

/* ============ 视频点击区（暂停/播放） ============ */
.video-tap-area {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.pause-indicator {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pauseEnter 200ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.pause-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 8rpx;
}

/* 顶部 / 底部柔光蒙层，提升白色文字可读性 */
.video-mask {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background:
    linear-gradient(
      to bottom,
      rgba(2, 6, 23, 0.55) 0%,
      rgba(2, 6, 23, 0) 18%,
      rgba(2, 6, 23, 0) 58%,
      rgba(2, 6, 23, 0.78) 100%
    );
}

/* ============ 顶部浮层 ============ */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: calc(20rpx + env(safe-area-inset-top)) 28rpx 16rpx;
  z-index: 10;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(12rpx);
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.back-btn:active {
  opacity: 0.65;
}

.back-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  line-height: 1;
  margin-top: -4rpx;
  font-weight: 300;
}

.progress-pill {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
}

.progress-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
  font-weight: 500;
}

/* ============ 右侧悬浮按钮栏 ============ */
.action-bar {
  position: absolute;
  right: 22rpx;
  top: auto;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  z-index: 10;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.action-item:active {
  opacity: 0.72;
}

.action-item:active .action-circle {
  transform: scale(0.96);
}

.action-circle {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(14rpx);
  transition:
    background 180ms cubic-bezier(0.22, 1, 0.36, 1),
    border 180ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 180ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.action-glyph {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.action-caption {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  letter-spacing: 0.5rpx;
}

.action-item.is-active .action-circle {
  background: rgba(37, 99, 235, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.30);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.40);
}

.action-circle-cta {
  background: rgba(37, 99, 235, 0.20);
  border: 1rpx solid rgba(96, 165, 250, 0.55);
}

.action-item-cta .action-glyph {
  color: #BFDBFE;
}

.action-circle-replay {
  background: rgba(16, 185, 129, 0.18);
  border: 1rpx solid rgba(110, 231, 183, 0.55);
  box-shadow: 0 6rpx 18rpx rgba(16, 185, 129, 0.20);
}

.action-item-replay .action-glyph {
  color: #A7F3D0;
}

.action-item-replay .action-caption {
  color: rgba(167, 243, 208, 0.92);
}

/* ============ 底部信息浮层（视频阶段） ============ */
.bottom-info {
  position: absolute;
  left: 28rpx;
  right: 160rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 5;
  pointer-events: none;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.scene-tag {
  background: rgba(37, 99, 235, 0.22);
  color: #BFDBFE;
  border: 1rpx solid rgba(96, 165, 250, 0.40);
}

.level-tag {
  background: rgba(16, 185, 129, 0.18);
  color: #A7F3D0;
  border: 1rpx solid rgba(52, 211, 153, 0.45);
}

.bottom-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.35;
  letter-spacing: 0.3rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.65);
}

.subtitle-overlay {
  margin-top: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  animation: subtitleEnter 200ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.subtitle-line {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.94);
  line-height: 1.55;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.75);
  letter-spacing: 0.3rpx;
}

/* ============ 底部抽屉通用 ============ */
.panel-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 6, 23, 0.55);
  z-index: 20;
  animation: fadeIn 220ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.panel-backdrop.backdrop-closing {
  animation: fadeOut 260ms ease-in both;
}

.panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.96);
  backdrop-filter: blur(20rpx);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 16rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 21;
  animation: panelSlideUp 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
  display: flex;
  flex-direction: column;
}

.panel.panel-closing {
  animation: panelSlideDown 260ms cubic-bezier(0.4, 0, 1, 0.6) both;
}

.panel-handle {
  width: 80rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  margin: 0 auto 20rpx;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
  transition: color 200ms cubic-bezier(0.22, 1, 0.36, 1);
}

.panel-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 1rpx;
}

/* ============ 词汇抽屉 ============ */
.glossary-panel {
  max-height: 70vh;
}

.glossary-scroll {
  flex: 1;
  max-height: 50vh;
}

.hint-toggle {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  transition: all 180ms cubic-bezier(0.22, 1, 0.36, 1);
}

.hint-toggle.is-on {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.20);
}

.hint-toggle-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.hint-toggle.is-on .hint-toggle-text {
  color: rgba(255, 255, 255, 0.88);
}

.glossary-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.glossary-item:last-child {
  border-bottom: none;
}

.word {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  letter-spacing: 0.3rpx;
}

.meaning {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.55;
}

.chinese-hint {
  display: block;
  font-size: 24rpx;
  color: rgba(191, 219, 254, 0.92);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ============ 答题抽屉 ============ */
.question-panel {
  max-height: 80vh;
}

.question-scroll {
  flex: 1;
  max-height: 56vh;
}

.question-text {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  line-height: 1.5;
  margin-bottom: 24rpx;
  letter-spacing: 0.3rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  transition:
    background 160ms cubic-bezier(0.22, 1, 0.36, 1),
    border 160ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 160ms cubic-bezier(0.22, 1, 0.36, 1),
    padding 160ms cubic-bezier(0.22, 1, 0.36, 1);
}

.option-index {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  text-align: center;
  line-height: 48rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  transition:
    background 160ms cubic-bezier(0.22, 1, 0.36, 1),
    border 160ms cubic-bezier(0.22, 1, 0.36, 1),
    color 160ms cubic-bezier(0.22, 1, 0.36, 1);
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.5;
  transition: color 160ms cubic-bezier(0.22, 1, 0.36, 1);
}

.option.active {
  background: rgba(37, 99, 235, 0.18);
  border: 2rpx solid #2563EB;
  padding: 21rpx 23rpx;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.14);
}

.option.active .option-index {
  background: #2563EB;
  border-color: #2563EB;
  color: #FFFFFF;
}

.option.active .option-text {
  color: #FFFFFF;
  font-weight: 500;
}

.panel-footer {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.primary-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: #2563EB;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.32);
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.primary-btn::after {
  border: none;
}

.primary-btn:active {
  background: #1D4ED8;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.30);
  opacity: 0.88;
}

.replay-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.replay-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 0.5rpx;
}

.replay-row:active {
  opacity: 0.72;
}

.replay-row:active .replay-text {
  color: rgba(255, 255, 255, 0.95);
}

.result {
  display: block;
  font-size: 26rpx;
  color: #6EE7B7;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* ============ 答题结果：标题颜色 ============ */
.result-title-correct {
  color: #34D399;
}

.result-title-wrong {
  color: #F87171;
}

/* ============ 答题结果反馈面板 ============ */
.feedback-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 12rpx;
  animation: resultFadeIn 240ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.feedback-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feedback-section-label {
  font-size: 20rpx;
  color: rgba(148, 163, 184, 0.75);
  letter-spacing: 2rpx;
  font-weight: 500;
}

.feedback-question-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.6;
  letter-spacing: 0.3rpx;
}

/* 正确答案卡片 */
.feedback-answer-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 22rpx;
  background: rgba(16, 185, 129, 0.10);
  border: 1rpx solid rgba(52, 211, 153, 0.26);
  border-radius: 16rpx;
}

.feedback-answer-badge {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(52, 211, 153, 0.20);
  border: 1rpx solid rgba(52, 211, 153, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-answer-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #34D399;
  line-height: 1;
}

.feedback-answer-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1.5;
  word-break: break-word;
  padding-top: 6rpx;
}

/* 解释卡片 */
.feedback-explanation-card {
  padding: 18rpx 20rpx;
  background: rgba(37, 99, 235, 0.08);
  border: 1rpx solid rgba(96, 165, 250, 0.18);
  border-radius: 14rpx;
}

.feedback-explanation-text {
  font-size: 26rpx;
  color: rgba(191, 219, 254, 0.85);
  line-height: 1.65;
  letter-spacing: 0.3rpx;
}

/* 继续下一条按钮变体（答错时橙色） */
.primary-btn-next {
  background: #D97706;
  box-shadow: 0 8rpx 24rpx rgba(217, 119, 6, 0.30);
}

.primary-btn-next:active {
  background: #B45309;
  box-shadow: 0 4rpx 12rpx rgba(217, 119, 6, 0.24);
}

/* ============ 关键帧 ============ */

/* 视频切换 */
@keyframes slideInFromBottom {
  from { opacity: 0; transform: translateY(18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideInFromTop {
  from { opacity: 0; transform: translateY(-18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 暂停图标浮现 */
@keyframes pauseEnter {
  from { opacity: 0; transform: translate(-50%, -50%) scale(0.88); }
  to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

/* 字幕浮现 */
@keyframes subtitleEnter {
  from { opacity: 0; transform: translateY(8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 面板打开 */
@keyframes panelSlideUp {
  from { opacity: 0; transform: translateY(44%); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 面板关闭 */
@keyframes panelSlideDown {
  from { opacity: 1; transform: translateY(0); }
  to   { opacity: 0; transform: translateY(44%); }
}

/* 背景遮罩显示 */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* 背景遮罩消失 */
@keyframes fadeOut {
  from { opacity: 1; }
  to   { opacity: 0; }
}

/* 答题结果反馈 */
@keyframes resultFadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
