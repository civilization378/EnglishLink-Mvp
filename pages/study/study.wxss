.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #222;
}

.subtitle {
  font-size: 30rpx;
  color: #444;
  line-height: 1.6;
}

.section {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}

.glossary-item {
  margin-bottom: 12rpx;
}

.word {
  font-weight: bold;
  margin-right: 16rpx;
}

.meaning {
  color: #666;
}

.question {
  margin-bottom: 20rpx;
  display: block;
  color: #333;
}

.option {
  padding: 20rpx;
  background: #f2f4f7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.option.active {
  background: #dfefff;
  border: 2rpx solid #4a90e2;
}

.result {
  font-size: 28rpx;
  color: #2c7;
}