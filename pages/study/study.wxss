/* ============================================================
 * Warm Cinema · 晨光影室 · Study
 * Dark video stage (warm-dark, never navy) for immersion;
 * drawer + options + feedback unified into Warm Cinema cream / amber / sage.
 * ============================================================ */

page {
  background: #1A1208; /* warm dark stage when video page is open */
}

/* ============ 根容器：全屏沉浸式 ============ */
.study-page {
  position: fixed;
  inset: 0;
  background: #1A1208;
  overflow: hidden;
  color: #FFFFFF;
}

/* ============ 动画内容层 ============ */
.slide-content {
  position: absolute;
  inset: 0;
  transition:
    opacity 240ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

.switching-next-out {
  opacity: 0;
  transform: translateY(-18rpx);
}

.switching-next-in {
  animation: slideInFromBottom 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.switching-prev-out {
  opacity: 0;
  transform: translateY(18rpx);
}

.switching-prev-in {
  animation: slideInFromTop 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

/* ============ 视频层 ============ */
.video-player {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: #000;
  z-index: 0;
}

.video-player-landscape,
.video-player-portrait {
  /* Sized by parent */
}

/* Switch mask: warm-dark instead of navy */
.switch-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26, 18, 8, 0.75), rgba(26, 18, 8, 0.55));
  z-index: 1;
  pointer-events: none;
  opacity: 0;
  transition: opacity 200ms cubic-bezier(0.22, 1, 0.36, 1);
}

.switch-mask-active {
  opacity: 0.65;
}

/* ============ 视频点击区（暂停/播放） ============ */
.video-tap-area {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.pause-indicator {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pauseEnter 200ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.pause-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 8rpx;
}

/* 顶部 / 底部柔光蒙层（warm-dark 替代 navy） */
.video-mask {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background:
    linear-gradient(
      to bottom,
      rgba(26, 18, 8, 0.55) 0%,
      rgba(26, 18, 8, 0) 18%,
      rgba(26, 18, 8, 0) 58%,
      rgba(26, 18, 8, 0.78) 100%
    );
}

/* ============ 顶部浮层 ============ */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: calc(60rpx + env(safe-area-inset-top)) 28rpx 16rpx;
  z-index: 10;
}

.back-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 28% 22%,
      rgba(255, 255, 255, 0.30) 0%,
      rgba(255, 255, 255, 0) 50%),
    rgba(42, 33, 24, 0.46);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx) saturate(1.1);
  -webkit-backdrop-filter: blur(20rpx) saturate(1.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.18),
    0 6rpx 18rpx rgba(0, 0, 0, 0.20);
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.back-btn:active {
  opacity: 0.65;
}

.back-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  line-height: 1;
  margin-top: -4rpx;
  font-weight: 300;
}

.progress-pill {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(42, 33, 24, 0.55);
  border: 1rpx solid rgba(247, 241, 232, 0.14);
  backdrop-filter: blur(12rpx);
}

.progress-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
  font-weight: 500;
}

/* ============ 右侧悬浮按钮栏（warm-dark 玻璃，琥珀强调） ============ */
.action-bar {
  position: absolute;
  right: 22rpx;
  top: auto;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  z-index: 10;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.action-item:active {
  opacity: 0.72;
}

.action-item:active .action-circle {
  transform: scale(0.96);
}

.action-circle {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  /* 多层暖灰玻璃：左上一点白光 + 主色暖灰半透明 */
  background:
    radial-gradient(circle at 28% 22%,
      rgba(255, 255, 255, 0.30) 0%,
      rgba(255, 255, 255, 0) 50%),
    rgba(42, 33, 24, 0.46);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx) saturate(1.1);
  -webkit-backdrop-filter: blur(20rpx) saturate(1.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.18),
    0 10rpx 24rpx rgba(0, 0, 0, 0.24);
  overflow: hidden;
  transition:
    background 180ms cubic-bezier(0.22, 1, 0.36, 1),
    border 180ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 180ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* Soft specular dot on each glass button — 不再是胶带，是一颗光点 */
.action-circle::before {
  content: "";
  position: absolute;
  top: 14rpx;
  left: 22rpx;
  width: 28rpx;
  height: 18rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center,
    rgba(255, 255, 255, 0.55) 0%,
    rgba(255, 255, 255, 0) 70%);
  filter: blur(2rpx);
  pointer-events: none;
}

.action-glyph {
  position: relative;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  z-index: 1;
}

.action-caption {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.84);
  letter-spacing: 0.5rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.45);
}

/* Active state (字幕/词汇 toggled) — warm amber */
.action-item.is-active .action-circle {
  background: rgba(217, 154, 43, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.40),
    0 10rpx 26rpx rgba(217, 154, 43, 0.42);
}

/* CTA "?" answer button — warm amber liquid glass halo */
.action-circle-cta {
  background:
    radial-gradient(circle at 28% 22%,
      rgba(255, 255, 255, 0.40) 0%,
      rgba(255, 255, 255, 0) 50%),
    rgba(217, 154, 43, 0.42);
  border: 1rpx solid rgba(245, 195, 100, 0.65);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
    inset 0 -1rpx 0 rgba(140, 86, 14, 0.22),
    0 10rpx 26rpx rgba(217, 154, 43, 0.36);
}

.action-item-cta .action-glyph {
  color: #FFF6E2;
}

/* Replay variant (kept; sage if used) */
.action-circle-replay {
  background: rgba(127, 165, 138, 0.22);
  border: 1rpx solid rgba(127, 165, 138, 0.55);
  box-shadow: 0 6rpx 18rpx rgba(127, 165, 138, 0.20);
}

.action-item-replay .action-glyph {
  color: #E3EFE6;
}

.action-item-replay .action-caption {
  color: rgba(227, 239, 230, 0.92);
}

/* ============ 底部信息浮层（视频阶段） ============ */
.bottom-info {
  position: absolute;
  left: 28rpx;
  right: 160rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 5;
  pointer-events: none;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* Scene tag — warm amber on dark video */
.scene-tag {
  background: rgba(217, 154, 43, 0.22);
  color: #FFE4A8;
  border: 1rpx solid rgba(245, 195, 100, 0.45);
}

/* Level tag — sage on dark video */
.level-tag {
  background: rgba(127, 165, 138, 0.22);
  color: #DDF1E2;
  border: 1rpx solid rgba(127, 165, 138, 0.50);
}

.bottom-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.35;
  letter-spacing: 0.3rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.65);
}

.subtitle-overlay {
  margin-top: 6rpx;
  animation: subtitleEnter 200ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

/* 字幕：深色半透明玻璃容器，确保任何视频底色都能读清 */
.subtitle-glass {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(26, 18, 8, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.22),
    0 6rpx 18rpx rgba(0, 0, 0, 0.20);
  backdrop-filter: blur(14rpx) saturate(1.05);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.05);
}

.subtitle-line {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.55;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.55);
  letter-spacing: 0.3rpx;
}

/* ============ 底部抽屉通用：Warm Cinema 奶油玻璃 ============ */
.panel-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(26, 18, 8, 0.55);
  z-index: 20;
  animation: fadeIn 220ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.panel-backdrop.backdrop-closing {
  animation: fadeOut 260ms ease-in both;
}

.panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  /* 多层奶油玻璃：左上白色晨光 + 右上暖金角光 + 左下鼠尾草微光 + 主体奶油半透明 */
  background:
    radial-gradient(circle at 14% 0%,
      rgba(255, 255, 255, 0.78) 0%,
      rgba(255, 255, 255, 0) 34%),
    radial-gradient(circle at 92% 6%,
      rgba(231, 175, 80, 0.18) 0%,
      rgba(231, 175, 80, 0) 40%),
    radial-gradient(circle at 8% 96%,
      rgba(127, 165, 138, 0.08) 0%,
      rgba(127, 165, 138, 0) 50%),
    rgba(255, 249, 239, 0.94);
  backdrop-filter: blur(24rpx) saturate(1.12);
  -webkit-backdrop-filter: blur(24rpx) saturate(1.12);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.82);
  border-left: 1rpx solid rgba(255, 255, 255, 0.55);
  border-right: 1rpx solid rgba(255, 255, 255, 0.55);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88),
    inset 0 -1rpx 0 rgba(217, 154, 43, 0.08),
    0 -22rpx 70rpx rgba(71, 52, 32, 0.22),
    0 -6rpx 18rpx rgba(71, 52, 32, 0.08);
  padding: 16rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 21;
  animation: panelSlideUp 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
  display: flex;
  flex-direction: column;
}

/* Soft warm glow stripe just above the panel — bridges video to drawer */
.panel::before {
  content: "";
  position: absolute;
  top: -1rpx;
  left: 18%;
  right: 18%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.92) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
}

.panel.panel-closing {
  animation: panelSlideDown 260ms cubic-bezier(0.4, 0, 1, 0.6) both;
}

.panel-handle {
  width: 64rpx;
  height: 4rpx;
  border-radius: 999rpx;
  /* 浅棕 / 半透明金的精致 handle，两端淡出像一抹晨光 */
  background: linear-gradient(
    90deg,
    rgba(180, 140, 80, 0) 0%,
    rgba(180, 140, 80, 0.34) 30%,
    rgba(217, 154, 43, 0.40) 50%,
    rgba(180, 140, 80, 0.34) 70%,
    rgba(180, 140, 80, 0) 100%
  );
  margin: 6rpx auto 20rpx;
}

/* 默认行布局：词汇抽屉等单行 header 沿用原有横向布局 */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  gap: 16rpx;
  min-height: 56rpx;
}

/* 答题结果状态：把 header 切换为纵向布局，让副文案换行显示 */
.panel-header-result {
  flex-direction: column;
  align-items: stretch;
  gap: 10rpx;
  margin-bottom: 28rpx;
}

.panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #3E3328;
  color: var(--text-main, #3E3328);
  letter-spacing: 0.5rpx;
  transition: color 200ms cubic-bezier(0.22, 1, 0.36, 1);
}

.panel-tag {
  font-size: 22rpx;
  color: #A99B8C;
  color: var(--text-faint, #A99B8C);
  letter-spacing: 1.6rpx;
  font-weight: 500;
  font-feature-settings: "tnum";
  line-height: 1;
  white-space: nowrap;
}

/* 答题结果：副文案，柔和不刺眼 */
.panel-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.55;
  letter-spacing: 0.3rpx;
  color: #7C6F62;
  color: var(--text-mute, #7C6F62);
  animation: resultFadeIn 280ms cubic-bezier(0.22, 1, 0.36, 1) 60ms both;
}

.panel-subtitle-correct {
  color: #5C9B7A;
}

.panel-subtitle-wrong {
  color: #B86A5E;
}

/* ============ 词汇抽屉 ============ */
.glossary-panel {
  max-height: 70vh;
}

.glossary-scroll {
  flex: 1;
  max-height: 50vh;
}

.hint-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 56rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(80, 60, 40, 0.06);
  border: 1rpx solid rgba(80, 60, 40, 0.10);
  transition: all 180ms cubic-bezier(0.22, 1, 0.36, 1);
}

.hint-toggle.is-on {
  background: rgba(217, 154, 43, 0.14);
  border: 1rpx solid rgba(217, 154, 43, 0.32);
}

.hint-toggle-text {
  font-size: 20rpx;
  color: #7C6F62;
  color: var(--text-mute, #7C6F62);
  font-weight: 500;
  letter-spacing: 0.3rpx;
  line-height: 1;
  white-space: nowrap;
}

.hint-toggle::after {
  content: "";
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: rgba(80, 60, 40, 0.16);
  border: 1rpx solid rgba(80, 60, 40, 0.20);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.55);
  transition: all 180ms cubic-bezier(0.22, 1, 0.36, 1);
}

.hint-toggle.is-on .hint-toggle-text {
  color: #B97818;
  color: var(--primary-press, #B97818);
}

.hint-toggle.is-on::after {
  background: linear-gradient(180deg, #E8B14C 0%, #DC9F30 100%);
  border-color: rgba(185, 120, 24, 0.30);
}

.glossary-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(80, 60, 40, 0.08);
}

.glossary-item:last-child {
  border-bottom: none;
}

.word {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  margin-bottom: 6rpx;
  letter-spacing: 0.3rpx;
}

.meaning {
  display: block;
  font-size: 26rpx;
  color: #3E3328;
  color: var(--text-main, #3E3328);
  line-height: 1.55;
}

.chinese-hint {
  display: block;
  font-size: 24rpx;
  color: #B97818;
  color: var(--primary-press, #B97818);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ============ 答题抽屉 ============ */
.question-panel {
  max-height: 80vh;
}

.question-scroll {
  flex: 1;
  max-height: 56vh;
}

.question-text {
  display: block;
  font-size: 33rpx;
  font-weight: 700;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  line-height: 1.4;
  margin-bottom: 28rpx;
  letter-spacing: 0.3rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 10rpx;
}

.option {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 84rpx;
  padding: 16rpx 24rpx;
  background:
    radial-gradient(circle at 20% 0%,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 255, 255, 0) 55%),
    rgba(255, 255, 255, 0.48);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72),
    0 4rpx 14rpx rgba(88, 61, 32, 0.05);
  transition:
    background 160ms cubic-bezier(0.22, 1, 0.36, 1),
    border 160ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 160ms cubic-bezier(0.22, 1, 0.36, 1),
    padding 160ms cubic-bezier(0.22, 1, 0.36, 1);
}

.option-index {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(80, 60, 40, 0.12);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #7C6F62;
  letter-spacing: 0.3rpx;
  line-height: 1;
  transition:
    background 160ms cubic-bezier(0.22, 1, 0.36, 1),
    border 160ms cubic-bezier(0.22, 1, 0.36, 1),
    color 160ms cubic-bezier(0.22, 1, 0.36, 1);
}

.option-text {
  flex: 1;
  display: flex;
  align-items: center;
  min-height: 48rpx;
  font-size: 28rpx;
  color: #3E3328;
  color: var(--text-main, #3E3328);
  line-height: 1.45;
  transition: color 160ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* Selected option — amber glass with left amber accent */
.option.active {
  background:
    radial-gradient(circle at 20% 0%,
      rgba(255, 255, 255, 0.45) 0%,
      rgba(255, 255, 255, 0) 55%),
    rgba(217, 154, 43, 0.14);
  border: 1rpx solid rgba(217, 154, 43, 0.55);
  padding: 16rpx 24rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.55),
    0 0 0 3rpx rgba(217, 154, 43, 0.14),
    0 8rpx 22rpx rgba(217, 154, 43, 0.18);
}

.option.active::before {
  content: "";
  position: absolute;
  top: 16rpx;
  bottom: 16rpx;
  left: 0;
  width: 4rpx;
  border-radius: 0 4rpx 4rpx 0;
  background: linear-gradient(180deg, #E5AB46 0%, #D99A2B 100%);
}

.option.active .option-index {
  background: #D99A2B;
  background: linear-gradient(180deg, #E5AB46 0%, #D99A2B 100%);
  border-color: rgba(255, 255, 255, 0.55);
  color: #FFFFFF;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.45),
    0 4rpx 12rpx rgba(217, 154, 43, 0.32);
}

.option.active .option-text {
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  font-weight: 600;
}

.panel-footer {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

/* ============ Primary CTA in drawer (amber lamp glass) ============ */
.primary-btn {
  position: relative;
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 auto;
  background: #D99A2B;
  background: linear-gradient(180deg, #E8B14C 0%, #DC9F30 55%, #C0851A 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1.2rpx;
  border-radius: 999rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 顶 inset 暖白 + 底 inset 暗金 + 外阴影：胶囊有厚度 */
  box-shadow:
    inset 0 2rpx 0 rgba(255, 232, 184, 0.55),
    inset 0 -2rpx 4rpx rgba(140, 86, 14, 0.20),
    0 16rpx 36rpx rgba(217, 154, 43, 0.34),
    0 6rpx 14rpx rgba(217, 154, 43, 0.20);
  overflow: hidden;
  transition:
    background 140ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 140ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 140ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.primary-btn::after {
  border: none;
}

/* 替代以前的横向白胶带：上方一团柔和奶油光斑（液态高光） */
.primary-btn::before {
  content: "";
  position: absolute;
  top: -50%;
  left: 18%;
  right: 18%;
  height: 130%;
  border-radius: 50%;
  background: radial-gradient(ellipse at center,
    rgba(255, 245, 220, 0.50) 0%,
    rgba(255, 245, 220, 0) 65%);
  filter: blur(10rpx);
  pointer-events: none;
}

.primary-btn:active {
  background: linear-gradient(180deg, #C7872A 0%, #A86B14 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28),
    inset 0 -1rpx 0 rgba(140, 86, 14, 0.20),
    0 8rpx 18rpx rgba(217, 154, 43, 0.24);
  transform: translateY(1rpx) scale(0.992);
  opacity: 0.96;
}

/* "Continue" stays warm amber whether correct or wrong */
.primary-btn-next {
  background: linear-gradient(180deg, #E8B14C 0%, #DC9F30 55%, #C0851A 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 232, 184, 0.55),
    inset 0 -2rpx 4rpx rgba(140, 86, 14, 0.20),
    0 16rpx 36rpx rgba(217, 154, 43, 0.34),
    0 6rpx 14rpx rgba(217, 154, 43, 0.20);
}

.primary-btn-next:active {
  background: linear-gradient(180deg, #C7872A 0%, #A86B14 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28),
    inset 0 -1rpx 0 rgba(140, 86, 14, 0.20),
    0 8rpx 18rpx rgba(217, 154, 43, 0.24);
}

.replay-row {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-top: 20rpx;
  padding: 2rpx 0 2rpx;
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.replay-text {
  font-size: 26rpx;
  color: #7C6F62;
  color: var(--text-mute, #7C6F62);
  letter-spacing: 0.5rpx;
  font-weight: 500;
}

.replay-row:active {
  opacity: 0.72;
}

.replay-row:active .replay-text {
  color: #2A2118;
  color: var(--text-strong, #2A2118);
}

/* ============ 答题结果：标题升级（更大、更柔、不刺眼） ============ */
.result-title-correct,
.result-title-wrong {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.result-title-correct {
  color: #5C9B7A;
}

.result-title-wrong {
  color: #C97163;
}

/* ============ 答题结果反馈面板 ============ */
.feedback-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 12rpx;
  animation: resultFadeIn 240ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.feedback-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feedback-section-label {
  font-size: 22rpx;
  color: #A99B8C;
  color: var(--text-faint, #A99B8C);
  letter-spacing: 1.5rpx;
  font-weight: 500;
}

.feedback-question-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #3E3328;
  color: var(--text-main, #3E3328);
  line-height: 1.6;
  letter-spacing: 0.3rpx;
}

/* 正确答案卡片 — soft sage glass，柔和不刺眼 */
.feedback-answer-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  background:
    radial-gradient(circle at 18% 0%,
      rgba(255, 255, 255, 0.58) 0%,
      rgba(255, 255, 255, 0) 50%),
    rgba(227, 239, 230, 0.72);
  border: 1rpx solid rgba(127, 165, 138, 0.32);
  border-radius: 20rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72),
    0 8rpx 20rpx rgba(127, 165, 138, 0.14);
  overflow: hidden;
}

.feedback-answer-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 12%;
  right: 12%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.7) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
}

.feedback-answer-badge {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 28% 22%,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 255, 255, 0) 60%),
    rgba(127, 165, 138, 0.36);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72),
    0 2rpx 6rpx rgba(127, 165, 138, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
}

.feedback-answer-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #5C9B7A;
  line-height: 1;
}

.feedback-answer-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  font-weight: 600;
  line-height: 1.5;
  word-break: break-word;
  padding-top: 6rpx;
}

/* 解释卡片 — 浅奶油磨砂玻璃，不发黄、不发灰 */
.feedback-explanation-card {
  position: relative;
  padding: 22rpx 24rpx;
  background:
    radial-gradient(circle at 18% 0%,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 255, 255, 0) 50%),
    rgba(252, 245, 232, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 20rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72),
    0 6rpx 18rpx rgba(88, 61, 32, 0.05);
  overflow: hidden;
}

.feedback-explanation-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 12%;
  right: 12%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.65) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
}

.feedback-explanation-text {
  font-size: 26rpx;
  color: #3E3328;
  color: var(--text-main, #3E3328);
  line-height: 1.65;
  letter-spacing: 0.3rpx;
}

/* ============ 关键帧 ============ */
@keyframes slideInFromBottom {
  from { opacity: 0; transform: translateY(18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideInFromTop {
  from { opacity: 0; transform: translateY(-18rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes pauseEnter {
  from { opacity: 0; transform: translate(-50%, -50%) scale(0.88); }
  to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

@keyframes subtitleEnter {
  from { opacity: 0; transform: translateY(8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes panelSlideUp {
  from { opacity: 0; transform: translateY(44%); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes panelSlideDown {
  from { opacity: 1; transform: translateY(0); }
  to   { opacity: 0; transform: translateY(44%); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to   { opacity: 0; }
}

@keyframes resultFadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
