/* ============================================================
 * Warm Liquid Glass · 晨光玻璃 · My / 学习档案
 * Cream paper base · sage accents for progress · soft coral for risk.
 * Translucent glass cards floating over softly-lit cream paper.
 * ============================================================ */

page {
  background: #F7F1E8;
  background: var(--bg-page, #F7F1E8);
}

/* ============ Root ============ */
.my-page {
  position: relative;
  min-height: 100vh;
  background: #F7F1E8;
  background:
    radial-gradient(circle at 8% 6%, rgba(217, 154, 43, 0.06) 0%, rgba(217, 154, 43, 0) 40%),
    radial-gradient(circle at 94% 94%, rgba(127, 165, 138, 0.05) 0%, rgba(127, 165, 138, 0) 42%),
    var(--bg-page, #F7F1E8);
  padding-bottom: calc(env(safe-area-inset-bottom) + 56rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  overflow: hidden;
  animation: pageFadeIn 280ms cubic-bezier(0.22, 1, 0.36, 1) both;
  animation: pageFadeIn 280ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
}

/* Lift content above ambient decoration */
.my-page > .top-bar,
.my-page > .hero-card,
.my-page > .stats-row,
.my-page > .history-card {
  position: relative;
  z-index: 1;
}

/* ============ Top bar ============ */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 20rpx) 28rpx 16rpx;
}

.back-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 249, 239, 0.78);
  background: var(--glass-bg, rgba(255, 249, 239, 0.78));
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border: 1rpx solid var(--glass-border, rgba(255, 255, 255, 0.72));
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(14rpx) saturate(1.05);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.05);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65),
    0 6rpx 18rpx rgba(88, 61, 32, 0.07);
  transition:
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1),
    background 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.back-btn:active {
  opacity: 0.78;
  background: #F1E6D6;
  background: var(--bg-surface-2, #F1E6D6);
}

.back-icon {
  font-size: 44rpx;
  color: #3E3328;
  color: var(--text-main, #3E3328);
  line-height: 1;
  margin-top: -4rpx;
  font-weight: 300;
}

.top-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  letter-spacing: 0.5rpx;
}

.top-placeholder {
  width: 64rpx;
}

/* ============ Hero card — cream glass ============ */
.hero-card {
  position: relative;
  margin: 0 32rpx;
  background: rgba(255, 249, 239, 0.88);
  background: var(--glass-bg-strong, rgba(255, 249, 239, 0.88));
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border: 1rpx solid var(--glass-border, rgba(255, 255, 255, 0.72));
  border-radius: 28rpx;
  border-radius: var(--radius-card, 28rpx);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 60rpx rgba(88, 61, 32, 0.10);
  box-shadow: var(--shadow-glass, 0 18rpx 60rpx rgba(88, 61, 32, 0.10));
  backdrop-filter: blur(18rpx) saturate(1.05);
  -webkit-backdrop-filter: blur(18rpx) saturate(1.05);
  animation: fadeSlideUp 320ms cubic-bezier(0.22, 1, 0.36, 1) both;
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
}

.hero-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 8%;
  right: 8%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.85) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
}

.hero-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  letter-spacing: 0.3rpx;
  flex: 1;
}

/* 与首页 glass-pill--brand 对齐：白色顶光 + 暖金底色 + 柔和阴影 */
.level-badge {
  position: relative;
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 30% 0%,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(255, 255, 255, 0) 60%),
    rgba(217, 154, 43, 0.16);
  border: 1rpx solid rgba(217, 154, 43, 0.35);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 4rpx 12rpx rgba(88, 61, 32, 0.06);
  backdrop-filter: blur(10rpx) saturate(1.05);
  -webkit-backdrop-filter: blur(10rpx) saturate(1.05);
}

.level-badge-text {
  font-size: 20rpx;
  color: #B97818;
  color: var(--primary-press, #B97818);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-card-subtitle {
  font-size: 24rpx;
  color: #7C6F62;
  color: var(--text-mute, #7C6F62);
  line-height: 1.55;
  letter-spacing: 0.3rpx;
}

/* ============ Stats — light glass strip ============ */
.stats-row {
  position: relative;
  margin: 0 32rpx;
  background: rgba(255, 249, 239, 0.72);
  background: var(--glass-bg, rgba(255, 249, 239, 0.72));
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border: 1rpx solid var(--glass-border, rgba(255, 255, 255, 0.68));
  border-radius: 28rpx;
  border-radius: var(--radius-card, 28rpx);
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  overflow: hidden;
  box-shadow: 0 10rpx 34rpx rgba(88, 61, 32, 0.07);
  box-shadow: var(--shadow-soft, 0 10rpx 34rpx rgba(88, 61, 32, 0.07));
  backdrop-filter: blur(14rpx) saturate(1.05);
  -webkit-backdrop-filter: blur(14rpx) saturate(1.05);
  animation: fadeSlideUp 340ms cubic-bezier(0.22, 1, 0.36, 1) 60ms both;
  animation: fadeSlideUp 340ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 60ms both;
}

.stats-row::before {
  content: "";
  position: absolute;
  top: 0;
  left: 12%;
  right: 12%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.7) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: linear-gradient(
    180deg,
    rgba(80, 60, 40, 0) 0%,
    rgba(80, 60, 40, 0.16) 50%,
    rgba(80, 60, 40, 0) 100%
  );
  flex-shrink: 0;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 700;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  letter-spacing: 0.3rpx;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #A99B8C;
  color: var(--text-faint, #A99B8C);
  letter-spacing: 0.5rpx;
}

/* Sage only when learner has data — applied via conditional class in wxml */
.stat-num--sage {
  color: #4FAE78;
  color: var(--correct, #4FAE78);
}

/* ============ History card — cream glass with airy separators ============ */
.history-card {
  position: relative;
  margin: 0 32rpx;
  background: rgba(255, 249, 239, 0.82);
  background: var(--glass-bg-strong, rgba(255, 249, 239, 0.82));
  border: 1rpx solid rgba(255, 255, 255, 0.68);
  border: 1rpx solid var(--glass-border, rgba(255, 255, 255, 0.68));
  border-radius: 28rpx;
  border-radius: var(--radius-card, 28rpx);
  padding: 30rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 44rpx rgba(88, 61, 32, 0.08);
  backdrop-filter: blur(16rpx) saturate(1.05);
  -webkit-backdrop-filter: blur(16rpx) saturate(1.05);
  animation: fadeSlideUp 340ms cubic-bezier(0.22, 1, 0.36, 1) 110ms both;
  animation: fadeSlideUp 340ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 110ms both;
}

.history-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.82) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  pointer-events: none;
}

.card-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  letter-spacing: 0.5rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.record-item-sep {
  position: relative;
}

.record-item-sep::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(80, 60, 40, 0) 0%,
    rgba(80, 60, 40, 0.10) 18%,
    rgba(80, 60, 40, 0.10) 82%,
    rgba(80, 60, 40, 0) 100%
  );
  pointer-events: none;
}

.record-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.record-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2A2118;
  color: var(--text-strong, #2A2118);
  line-height: 1.45;
  letter-spacing: 0.3rpx;
}

.result-badge {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.badge-correct {
  background: rgba(127, 165, 138, 0.14);
  border: 1rpx solid rgba(127, 165, 138, 0.40);
}

.badge-wrong {
  background: rgba(217, 108, 95, 0.10);
  border: 1rpx solid rgba(217, 108, 95, 0.32);
}

.result-badge-text {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
}

.badge-correct .result-badge-text {
  color: #4FAE78;
  color: var(--correct, #4FAE78);
}

.badge-wrong .result-badge-text {
  color: #D96C5F;
  color: var(--wrong, #D96C5F);
}

.record-question {
  font-size: 24rpx;
  color: #7C6F62;
  color: var(--text-mute, #7C6F62);
  line-height: 1.55;
  letter-spacing: 0.2rpx;
}

.record-time {
  font-size: 22rpx;
  color: #A99B8C;
  color: var(--text-faint, #A99B8C);
  letter-spacing: 0.2rpx;
}

/* ============ Empty state ============ */
.empty-state {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 0 8rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #7C6F62;
  color: var(--text-mute, #7C6F62);
  font-weight: 500;
}

.empty-desc {
  font-size: 24rpx;
  color: #A99B8C;
  color: var(--text-faint, #A99B8C);
  line-height: 1.6;
  letter-spacing: 0.2rpx;
}

/* ============ Clear button (de-emphasized danger) ============ */
.clear-row {
  display: flex;
  justify-content: flex-start;
  padding-top: 4rpx;
}

.clear-btn {
  padding: 14rpx 28rpx;
  border: 1rpx solid rgba(217, 108, 95, 0.32);
  border-radius: 999rpx;
  background: rgba(217, 108, 95, 0.06);
  transition:
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1),
    background 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.clear-btn:active {
  opacity: 0.78;
  background: rgba(217, 108, 95, 0.12);
}

.clear-btn-text {
  font-size: 24rpx;
  color: #D96C5F;
  color: var(--wrong, #D96C5F);
  letter-spacing: 0.5rpx;
  font-weight: 600;
}

/* ============ Keyframes ============ */
@keyframes pageFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
