page {
  background: #020617;
}

/* ============ 根容器：可滚动卡片布局 ============ */
.index-page {
  min-height: 100vh;
  background: #020617;
  padding: calc(env(safe-area-inset-top) + 48rpx) 32rpx calc(env(safe-area-inset-bottom) + 56rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ============ 顶部 Hero ============ */
.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 4rpx;
  animation: fadeSlideUp 320ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.hero-left {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #F8FAFC;
  letter-spacing: 0.5rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: #94A3B8;
  letter-spacing: 0.3rpx;
}

.accuracy-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  padding: 12rpx 24rpx;
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 999rpx;
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.accuracy-pill:active {
  opacity: 0.68;
}

.accuracy-label {
  font-size: 18rpx;
  color: #94A3B8;
  letter-spacing: 0.5rpx;
}

.accuracy-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #10B981;
  letter-spacing: 0.3rpx;
}

/* ============ 今日推荐主卡片 ============ */
.main-card {
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  animation: fadeSlideUp 360ms cubic-bezier(0.22, 1, 0.36, 1) 60ms both;
}

.main-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-label {
  font-size: 22rpx;
  color: #94A3B8;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.progress-badge {
  font-size: 22rpx;
  color: #94A3B8;
  padding: 4rpx 18rpx;
  background: rgba(148, 163, 184, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 999rpx;
}

.main-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #F8FAFC;
  line-height: 1.4;
  letter-spacing: 0.3rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.scene-tag {
  background: rgba(37, 99, 235, 0.20);
  color: #BFDBFE;
  border: 1rpx solid rgba(96, 165, 250, 0.38);
}

.level-tag {
  background: rgba(16, 185, 129, 0.16);
  color: #A7F3D0;
  border: 1rpx solid rgba(52, 211, 153, 0.40);
}

.done-tag {
  background: rgba(16, 185, 129, 0.20);
  color: #A7F3D0;
  border: 1rpx solid rgba(52, 211, 153, 0.42);
}

/* 封面区域 */
.cover-area {
  height: 280rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #0e1e45 0%, #060c1c 60%, #020917 100%);
  border: 1rpx solid rgba(96, 165, 250, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 12rpx 40rpx rgba(0, 0, 0, 0.50),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  transition:
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.cover-area:active {
  opacity: 0.86;
  transform: scale(0.99);
}

.cover-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  margin-top: -150rpx;
  margin-left: -150rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.22) 0%, transparent 70%);
  pointer-events: none;
}

.play-ring {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.22);
  border: 2rpx solid rgba(96, 165, 250, 0.58);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(37, 99, 235, 0.32);
  z-index: 1;
}

.play-icon {
  font-size: 44rpx;
  color: #BFDBFE;
  margin-left: 8rpx;
  line-height: 1;
}

/* 开始按钮 */
.start-btn {
  height: 88rpx;
  background: #2563EB;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.32);
  transition:
    background 140ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 140ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 140ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.start-btn:active {
  background: #1D4ED8;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.24);
  transform: scale(0.98);
  opacity: 0.92;
}

.start-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

/* ============ 学习统计卡片 ============ */
.stats-row {
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  animation: fadeSlideUp 340ms cubic-bezier(0.22, 1, 0.36, 1) 120ms both;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(148, 163, 184, 0.14);
  flex-shrink: 0;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 700;
  color: #F8FAFC;
  letter-spacing: 0.3rpx;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #94A3B8;
  letter-spacing: 0.5rpx;
}

/* ============ 今日目标卡片 ============ */
.goal-card {
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 28rpx;
  padding: 30rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  animation: fadeSlideUp 320ms cubic-bezier(0.22, 1, 0.36, 1) 170ms both;
}

.goal-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #F8FAFC;
  letter-spacing: 0.5rpx;
}

.goal-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.goal-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.goal-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2563EB;
  flex-shrink: 0;
}

.goal-text {
  font-size: 26rpx;
  color: #94A3B8;
  line-height: 1.5;
}

/* ============ 底部弱按钮 ============ */
.bottom-action {
  display: flex;
  justify-content: center;
  padding-top: 4rpx;
  animation: fadeSlideUp 280ms cubic-bezier(0.22, 1, 0.36, 1) 210ms both;
}

.ghost-btn {
  padding: 18rpx 56rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 999rpx;
  transition: opacity 140ms cubic-bezier(0.22, 1, 0.36, 1), background 140ms cubic-bezier(0.22, 1, 0.36, 1);
}

.ghost-btn:active {
  opacity: 0.62;
  background: rgba(148, 163, 184, 0.06);
}

.ghost-btn-text {
  font-size: 26rpx;
  color: #94A3B8;
  letter-spacing: 0.5rpx;
}

/* ============ 关键帧 ============ */
@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
