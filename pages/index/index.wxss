/* ============================================================
 * Forest Spatial Glass · Home
 * 深绿森林壁纸 + 浮动暗色烟熏玻璃控件
 * 设计原则：空间感 / 可读性 / 克制 / 不贴纸 / 不水滴 / 不洗白
 * ============================================================ */

/* 加载兜底：深森林色，避免冷启动闪白 */
page {
  background: #0E1410;
}

/* ============ Page · 仅作图片加载兜底，不洗白壁纸 ============ */
.index-page {
  position: relative;
  min-height: 100vh;
  background: #0E1410;
  padding: calc(env(safe-area-inset-top) + 56rpx) 32rpx calc(env(safe-area-inset-bottom) + 64rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  overflow: hidden;
  animation: pageFadeIn 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
}

/* 内容层永远在壁纸之上 */
.index-page > .hero,
.index-page > .scene-card,
.index-page > .stats-row,
.index-page > .path-panel,
.index-page > .profile-link {
  position: relative;
  z-index: 1;
}

/* ============ Wallpaper · 森林壁纸层 ============ */
.wallpaper {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

/* 壁纸图：完整清晰显示，无 blur / 无降透明 / 无饱和洗白 */
.wallpaper-image {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 1;
  filter: none;
  transform: none;
  pointer-events: none;
}

/* 极轻暗色 vignette：仅用于托住 Hero 与底部 CTA 文字，不洗白原图 */
.wallpaper-vignette {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
  background:
    linear-gradient(180deg,
      rgba(8, 14, 10, 0.42) 0%,
      rgba(8, 14, 10, 0.10) 18%,
      rgba(8, 14, 10, 0.00) 42%,
      rgba(8, 14, 10, 0.10) 76%,
      rgba(8, 14, 10, 0.38) 100%);
}

/* ============ Hero · 浮在壁纸上的暖白主标 ============ */
.hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 8rpx 4rpx 4rpx;
  animation: fadeSlideUp 420ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 40ms both;
}

.hero-eyebrow {
  font-size: 22rpx;
  color: #E8C77D;
  letter-spacing: 8rpx;
  font-weight: 700;
  text-shadow:
    0 1rpx 8rpx rgba(0, 0, 0, 0.55),
    0 1rpx 2rpx rgba(0, 0, 0, 0.45);
}

.hero-title {
  font-size: 54rpx;
  font-weight: 700;
  color: #F7EFD9;
  letter-spacing: -0.3rpx;
  line-height: 1.14;
  text-shadow:
    0 2rpx 18rpx rgba(0, 0, 0, 0.55),
    0 1rpx 2rpx rgba(0, 0, 0, 0.50),
    0 0 28rpx rgba(0, 0, 0, 0.30);
}

.hero-subtitle {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(245, 239, 226, 0.78);
  line-height: 1.55;
  letter-spacing: 0.3rpx;
  max-width: 560rpx;
  margin-top: 4rpx;
  text-shadow:
    0 1rpx 8rpx rgba(0, 0, 0, 0.55),
    0 1rpx 2rpx rgba(0, 0, 0, 0.40);
}

/* ============ Glass Sheen · 卡片顶部 1rpx 玻璃唇高光 ============ */
.card-sheen {
  position: absolute;
  top: 0;
  left: 8%;
  right: 8%;
  height: 1rpx;
  background: linear-gradient(90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0) 100%);
  pointer-events: none;
}

.card-sheen--narrow {
  left: 18%;
  right: 18%;
  background: linear-gradient(90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.45) 50%,
    rgba(255, 255, 255, 0) 100%);
}

/* ============ Scene Card · 主卡 暗色烟熏玻璃 ============ */
.scene-card {
  position: relative;
  border-radius: 32rpx;
  padding: 32rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  overflow: hidden;
  background: rgba(15, 20, 16, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-shadow:
    0 28rpx 80rpx rgba(0, 0, 0, 0.36),
    0 6rpx 18rpx rgba(0, 0, 0, 0.22),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.28),
    inset 0 -1rpx 1rpx rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(30rpx) saturate(1.25);
  -webkit-backdrop-filter: blur(30rpx) saturate(1.25);
  animation: fadeSlideUp 460ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 100ms both;
}

.scene-card-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

/* ============ Pill · 玻璃药丸标签 ============ */
.pill {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.pill-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.pill--brand {
  background: rgba(217, 154, 43, 0.18);
  border-color: rgba(232, 187, 95, 0.42);
}

.pill-text--brand {
  color: #F0C57A;
}

.pill--ghost {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.16);
}

.pill-text--ghost {
  color: rgba(245, 239, 226, 0.78);
  font-weight: 600;
  letter-spacing: 1.5rpx;
}

.pill--mint {
  background: rgba(111, 211, 154, 0.16);
  border-color: rgba(111, 211, 154, 0.42);
}

.pill-text--mint {
  color: #8BDFB0;
  letter-spacing: 2rpx;
}

/* ============ Scene Card 内文 ============ */
.scene-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #F7EFD9;
  line-height: 1.22;
  letter-spacing: 0.2rpx;
  margin-top: 4rpx;
}

.meta-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
}

.meta-text {
  font-size: 24rpx;
  color: rgba(245, 239, 226, 0.72);
  letter-spacing: 0.3rpx;
}

.meta-dot {
  font-size: 24rpx;
  color: rgba(245, 239, 226, 0.42);
}

.hook-text {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  color: rgba(245, 239, 226, 0.62);
  line-height: 1.6;
  letter-spacing: 0.2rpx;
  padding: 4rpx 0 2rpx;
}

/* ============ CTA · 暖金主按钮（页面唯一强 CTA） ============ */
.cta-button {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  height: 100rpx;
  border-radius: 999rpx;
  border-radius: var(--radius-pill, 999rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #F0B94B 0%, #D99A2B 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 232, 184, 0.55),
    inset 0 -2rpx 4rpx rgba(140, 86, 14, 0.20),
    0 14rpx 34rpx rgba(217, 154, 43, 0.34),
    0 4rpx 12rpx rgba(217, 154, 43, 0.20);
  transition:
    transform 160ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
    box-shadow 160ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
    opacity 160ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
}

.cta-text {
  position: relative;
  z-index: 1;
  font-size: 31rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1.2rpx;
  text-shadow: 0 1rpx 2rpx rgba(120, 70, 10, 0.28);
}

.cta-button--press {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.96;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.30),
    inset 0 -1rpx 0 rgba(140, 86, 14, 0.18),
    0 8rpx 18rpx rgba(217, 154, 43, 0.24);
}

/* ============ Stats · 三个暗玻璃统计控件 ============ */
.stats-row {
  display: flex;
  gap: 14rpx;
  animation: fadeSlideUp 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 200ms both;
}

.stat-card {
  position: relative;
  flex: 1;
  border-radius: 26rpx;
  padding: 24rpx 12rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  overflow: hidden;
  background: rgba(15, 20, 16, 0.38);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    0 18rpx 40rpx rgba(0, 0, 0, 0.28),
    0 4rpx 10rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.20),
    inset 0 -1rpx 1rpx rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(26rpx) saturate(1.20);
  -webkit-backdrop-filter: blur(26rpx) saturate(1.20);
}

.stat-card:nth-child(1) {
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 220ms both;
}

.stat-card:nth-child(2) {
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 280ms both;
}

.stat-card:nth-child(3) {
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 340ms both;
}

.stat-num {
  position: relative;
  z-index: 1;
  font-size: 44rpx;
  font-weight: 700;
  color: #F7EFD9;
  letter-spacing: 0.3rpx;
  line-height: 1.2;
  font-feature-settings: "tnum";
}

/* 正确率：柔和薄荷绿，非荧光绿 */
.stat-num--mint {
  color: #6FD39A;
}

.stat-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(245, 239, 226, 0.58);
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

/* ============ Path Panel · 训练路径 弱一档暗玻璃 ============ */
.path-panel {
  position: relative;
  border-radius: 30rpx;
  padding: 28rpx 30rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  overflow: hidden;
  background: rgba(15, 20, 16, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow:
    0 18rpx 44rpx rgba(0, 0, 0, 0.26),
    0 4rpx 10rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.18),
    inset 0 -1rpx 1rpx rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(28rpx) saturate(1.18);
  -webkit-backdrop-filter: blur(28rpx) saturate(1.18);
  animation: fadeSlideUp 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 280ms both;
}

.panel-title {
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(245, 239, 226, 0.78);
  letter-spacing: 1.5rpx;
}

.panel-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.panel-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.panel-num {
  font-size: 22rpx;
  font-weight: 700;
  color: #F0C57A;
  letter-spacing: 1rpx;
  width: 44rpx;
  flex-shrink: 0;
  font-feature-settings: "tnum";
}

.panel-text {
  font-size: 26rpx;
  color: rgba(245, 239, 226, 0.86);
  line-height: 1.5;
  letter-spacing: 0.2rpx;
}

/* ============ Profile Link · 暗玻璃文字胶囊 ============ */
.profile-link {
  margin: 4rpx auto 0;
  padding: 16rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: rgba(15, 20, 16, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow:
    0 10rpx 24rpx rgba(0, 0, 0, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(20rpx) saturate(1.12);
  -webkit-backdrop-filter: blur(20rpx) saturate(1.12);
  transition:
    opacity 140ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
    background 140ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
  animation: fadeIn 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 360ms both;
}

.profile-link--press {
  opacity: 0.86;
  background: rgba(15, 20, 16, 0.50);
}

.profile-link-text {
  font-size: 24rpx;
  color: rgba(245, 239, 226, 0.82);
  letter-spacing: 1.2rpx;
}

/* ============ Keyframes ============ */
@keyframes pageFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
