/* ============================================================
 * Forest Spatial Glass · Home (single-image edition)
 * 仅使用 home-forest-bg.png 一张图，靠 CSS 模拟 iOS 空间壁纸：
 *   照片 → 系统级处理（brightness/saturate/contrast）
 *   + 顶部 ambient 光 + 底部暗场（大气纵深）
 *   + 边缘 vignette（取景框 / 照片质感）
 *   + 液态玻璃卡片（顶亮底暗的渐变玻璃 + 强 inset 高光 + 强外阴影）
 * 不使用任何前景抠图素材，不做水滴贴纸装饰。
 * ============================================================ */

page {
  background: #0E1410;
}

/* ============ Page · 深色兜底底色，避免冷启动闪白 ============ */
.index-page {
  position: relative;
  min-height: 100vh;
  background: #0E1410;
  overflow: hidden;
  animation: pageFadeIn 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
}

/* ============ 第一层：wallpaper layer（仅壁纸） ============ */
.wallpaper {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

/* 照片：iOS 锁屏式系统级图像处理 —— 不洗白，但有"被处理过"的高级感 */
.wallpaper-photo {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: brightness(0.72) saturate(1.05) contrast(1.04);
}

/* ============ 第二层：depth overlay layer（可读性保护） ============ */
.depth-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1;
  pointer-events: none;
}

/* 大气纵深：顶部 ambient 暖光（模拟天空进光） + 底部暗场（模拟林下） */
.wallpaper-depth {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse 100% 60% at 50% 0%,
      rgba(255, 246, 220, 0.10) 0%,
      rgba(255, 246, 220, 0) 60%),
    linear-gradient(180deg,
      rgba(0, 0, 0, 0.04) 0%,
      rgba(0, 0, 0, 0.06) 36%,
      rgba(0, 0, 0, 0.18) 70%,
      rgba(0, 0, 0, 0.36) 100%);
}

/* 照片级 vignette：四角自然压暗，让照片像被取景框框住 */
.wallpaper-vignette {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse 130% 80% at 50% 50%,
      rgba(0, 0, 0, 0) 56%,
      rgba(0, 0, 0, 0.32) 100%);
}

/* ============ 第三层：content layer ============ */
.content-layer {
  position: relative;
  z-index: 10;
  padding: calc(env(safe-area-inset-top) + 56rpx) 32rpx calc(env(safe-area-inset-bottom) + 64rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* ============ Hero · 像系统锁屏文字一样浮在照片上 ============ */
.hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 8rpx 4rpx 4rpx;
  animation: fadeSlideUp 420ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 40ms both;
}

.hero-eyebrow {
  font-size: 22rpx;
  color: #E8C77D;
  letter-spacing: 8rpx;
  font-weight: 700;
  text-shadow:
    0 1rpx 8rpx rgba(0, 0, 0, 0.55),
    0 1rpx 2rpx rgba(0, 0, 0, 0.45);
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #F7F2E6;
  letter-spacing: -0.4rpx;
  line-height: 1.14;
  text-shadow:
    0 4rpx 18rpx rgba(0, 0, 0, 0.45),
    0 1rpx 2rpx rgba(0, 0, 0, 0.50);
}

.hero-subtitle {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(247, 242, 230, 0.76);
  line-height: 1.55;
  letter-spacing: 0.3rpx;
  max-width: 520rpx;
  margin-top: 4rpx;
  text-shadow:
    0 1rpx 8rpx rgba(0, 0, 0, 0.55),
    0 1rpx 2rpx rgba(0, 0, 0, 0.40);
}

/* ============ Glass Sheen · 卡片顶部 1rpx 玻璃唇高光 ============ */
.card-sheen {
  position: absolute;
  top: 0;
  left: 8%;
  right: 8%;
  height: 1rpx;
  background: linear-gradient(90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0) 100%);
  pointer-events: none;
}

.card-sheen--narrow {
  left: 18%;
  right: 18%;
  background: linear-gradient(90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.45) 50%,
    rgba(255, 255, 255, 0) 100%);
}

/* ============ Scene Card · 主卡 真液态玻璃（顶亮底暗的渐变玻璃） ============ */
.scene-card {
  position: relative;
  border-radius: 32rpx;
  padding: 32rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  overflow: hidden;
  background: linear-gradient(180deg,
    rgba(16, 24, 18, 0.58) 0%,
    rgba(10, 16, 12, 0.46) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.20);
  box-shadow:
    0 30rpx 90rpx rgba(0, 0, 0, 0.38),
    0 8rpx 24rpx rgba(0, 0, 0, 0.20),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.32),
    inset 0 -1rpx 1rpx rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(30rpx) saturate(1.22);
  -webkit-backdrop-filter: blur(30rpx) saturate(1.22);
  animation: fadeSlideUp 460ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 100ms both;
}

.scene-card-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

/* ============ Pill · 玻璃药丸标签 ============ */
.pill {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.pill-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.pill--brand {
  background: rgba(217, 154, 43, 0.20);
  border-color: rgba(232, 187, 95, 0.46);
}

.pill-text--brand {
  color: #F0C57A;
}

.pill--ghost {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.18);
}

.pill-text--ghost {
  color: rgba(248, 243, 232, 0.78);
  font-weight: 600;
  letter-spacing: 1.5rpx;
}

.pill--mint {
  background: rgba(105, 217, 154, 0.16);
  border-color: rgba(105, 217, 154, 0.44);
}

.pill-text--mint {
  color: #8BE3B0;
  letter-spacing: 2rpx;
}

/* ============ Scene Card 内文 ============ */
.scene-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #F8F3E8;
  line-height: 1.22;
  letter-spacing: 0.2rpx;
  margin-top: 4rpx;
}

.meta-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
}

.meta-text {
  font-size: 24rpx;
  color: rgba(248, 243, 232, 0.72);
  letter-spacing: 0.3rpx;
}

.meta-dot {
  font-size: 24rpx;
  color: rgba(248, 243, 232, 0.42);
}

.hook-text {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  color: rgba(248, 243, 232, 0.62);
  line-height: 1.6;
  letter-spacing: 0.2rpx;
  padding: 4rpx 0 2rpx;
}

/* ============ CTA · 暖金主按钮（首页唯一强 CTA，照片上的发光控件） ============ */
.cta-button {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  height: 100rpx;
  border-radius: 999rpx;
  border-radius: var(--radius-pill, 999rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #F0B94B 0%, #D99A2B 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 232, 184, 0.55),
    inset 0 -2rpx 4rpx rgba(140, 86, 14, 0.20),
    0 16rpx 40rpx rgba(217, 154, 43, 0.42),
    0 4rpx 12rpx rgba(217, 154, 43, 0.22);
  transition:
    transform 160ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
    box-shadow 160ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
    opacity 160ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
}

.cta-text {
  position: relative;
  z-index: 1;
  font-size: 31rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1.2rpx;
  text-shadow: 0 1rpx 2rpx rgba(120, 70, 10, 0.28);
}

.cta-button--press {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.96;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.30),
    inset 0 -1rpx 0 rgba(140, 86, 14, 0.18),
    0 8rpx 18rpx rgba(217, 154, 43, 0.28);
}

/* ============ Stats · 三个小玻璃控件（iOS 风小尺寸） ============ */
.stats-row {
  display: flex;
  gap: 14rpx;
  animation: fadeSlideUp 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 200ms both;
}

.stat-card {
  position: relative;
  flex: 1;
  border-radius: 26rpx;
  padding: 24rpx 12rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  overflow: hidden;
  background: linear-gradient(180deg,
    rgba(16, 24, 18, 0.50) 0%,
    rgba(10, 16, 12, 0.40) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-shadow:
    0 18rpx 44rpx rgba(0, 0, 0, 0.30),
    0 4rpx 10rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.24),
    inset 0 -1rpx 1rpx rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(26rpx) saturate(1.20);
  -webkit-backdrop-filter: blur(26rpx) saturate(1.20);
}

.stat-card:nth-child(1) {
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 220ms both;
}

.stat-card:nth-child(2) {
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 280ms both;
}

.stat-card:nth-child(3) {
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 340ms both;
}

.stat-num {
  position: relative;
  z-index: 1;
  font-size: 44rpx;
  font-weight: 700;
  color: #F8F3E8;
  letter-spacing: 0.3rpx;
  line-height: 1.2;
  font-feature-settings: "tnum";
}

/* 正确率：柔和薄荷绿 */
.stat-num--mint {
  color: #69D99A;
}

.stat-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(248, 243, 232, 0.62);
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

/* ============ Path Panel · 训练路径 弱一档玻璃面板 ============ */
.path-panel {
  position: relative;
  border-radius: 30rpx;
  padding: 28rpx 30rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  overflow: hidden;
  background: linear-gradient(180deg,
    rgba(16, 24, 18, 0.42) 0%,
    rgba(10, 16, 12, 0.32) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow:
    0 18rpx 44rpx rgba(0, 0, 0, 0.26),
    0 4rpx 10rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.22),
    inset 0 -1rpx 1rpx rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(28rpx) saturate(1.18);
  -webkit-backdrop-filter: blur(28rpx) saturate(1.18);
  animation: fadeSlideUp 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 280ms both;
}

.panel-title {
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(248, 243, 232, 0.82);
  letter-spacing: 1.5rpx;
}

.panel-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.panel-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.panel-num {
  font-size: 22rpx;
  font-weight: 700;
  color: #E8B84A;
  letter-spacing: 1rpx;
  width: 44rpx;
  flex-shrink: 0;
  font-feature-settings: "tnum";
}

.panel-text {
  font-size: 26rpx;
  color: rgba(248, 243, 232, 0.82);
  line-height: 1.5;
  letter-spacing: 0.2rpx;
}

/* ============ Profile Link · 弱玻璃文字胶囊 ============ */
.profile-link {
  margin: 4rpx auto 0;
  padding: 16rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: linear-gradient(180deg,
    rgba(16, 24, 18, 0.40) 0%,
    rgba(10, 16, 12, 0.30) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow:
    0 10rpx 24rpx rgba(0, 0, 0, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(20rpx) saturate(1.12);
  -webkit-backdrop-filter: blur(20rpx) saturate(1.12);
  transition:
    opacity 140ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
    background 140ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
  animation: fadeIn 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 360ms both;
}

.profile-link--press {
  opacity: 0.86;
  background: linear-gradient(180deg,
    rgba(16, 24, 18, 0.56) 0%,
    rgba(10, 16, 12, 0.46) 100%);
}

.profile-link-text {
  font-size: 24rpx;
  color: rgba(248, 243, 232, 0.82);
  letter-spacing: 1.2rpx;
}

/* ============ Keyframes ============ */
@keyframes pageFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
