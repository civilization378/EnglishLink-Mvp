/* ============================================================
 * Aurora Cinema · 极光影室 · Home
 * Cinema-room navy. Electric-blue CTA. Mint reserved for progress.
 * ============================================================ */

page {
  background: #0A0F1F;
  background: var(--bg-page, #0A0F1F);
}

/* ============ Root ============ */
.index-page {
  min-height: 100vh;
  background: #0A0F1F;
  background: var(--bg-page, #0A0F1F);
  padding: calc(env(safe-area-inset-top) + 56rpx) 32rpx calc(env(safe-area-inset-bottom) + 64rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  animation: pageFadeIn 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
  animation: pageFadeIn 300ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) both;
}

/* ============ Hero ============ */
.hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 12rpx 4rpx 4rpx;
  animation: fadeSlideUp 320ms cubic-bezier(0.22, 1, 0.36, 1) 40ms both;
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 40ms both;
}

.hero-eyebrow {
  font-size: 22rpx;
  color: #5B6884;
  color: var(--text-faint, #5B6884);
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #F8FAFC;
  color: var(--text-strong, #F8FAFC);
  letter-spacing: 1rpx;
  line-height: 1.18;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #9CA8C0;
  color: var(--text-mute, #9CA8C0);
  line-height: 1.55;
  letter-spacing: 0.3rpx;
  max-width: 560rpx;
}

/* ============ Today recommendation card ============ */
.main-card {
  position: relative;
  background: rgba(15, 23, 42, 0.55);
  background: var(--bg-glass, rgba(15, 23, 42, 0.55));
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border: 1rpx solid var(--hairline, rgba(255, 255, 255, 0.06));
  border-radius: 28rpx;
  border-radius: var(--radius-card, 28rpx);
  padding: 32rpx 32rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  overflow: hidden;
  animation: fadeSlideUp 360ms cubic-bezier(0.22, 1, 0.36, 1) 100ms both;
  animation: fadeSlideUp 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 100ms both;
}

/* Quiet ambient glow at the corner — never loud */
.main-card-glow {
  position: absolute;
  top: -160rpx;
  right: -120rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 124, 255, 0.16) 0%, transparent 65%);
  pointer-events: none;
}

.main-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.scene-chip {
  font-size: 22rpx;
  font-weight: 600;
  color: #9CA8C0;
  color: var(--text-mute, #9CA8C0);
  letter-spacing: 4rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: rgba(79, 124, 255, 0.10);
  border: 1rpx solid rgba(79, 124, 255, 0.22);
}

.progress-badge {
  font-size: 22rpx;
  color: #5B6884;
  color: var(--text-faint, #5B6884);
  letter-spacing: 1rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border: 1rpx solid var(--hairline, rgba(255, 255, 255, 0.06));
}

.progress-badge--done {
  color: #5EEAD4;
  color: var(--aurora-mint, #5EEAD4);
  background: rgba(94, 234, 212, 0.08);
  border-color: rgba(94, 234, 212, 0.28);
}

.main-card-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #F8FAFC;
  color: var(--text-strong, #F8FAFC);
  line-height: 1.32;
  letter-spacing: 0.3rpx;
  position: relative;
  z-index: 1;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.meta-text {
  font-size: 24rpx;
  color: #9CA8C0;
  color: var(--text-mute, #9CA8C0);
  letter-spacing: 0.3rpx;
}

.meta-dot {
  font-size: 24rpx;
  color: #5B6884;
  color: var(--text-faint, #5B6884);
}

.hook-text {
  font-size: 24rpx;
  color: #9CA8C0;
  color: var(--text-mute, #9CA8C0);
  line-height: 1.55;
  letter-spacing: 0.2rpx;
  padding: 10rpx 0 4rpx;
  position: relative;
  z-index: 1;
}

/* ============ Primary CTA ============ */
.primary-btn {
  margin-top: 8rpx;
  height: 96rpx;
  background: #4F7CFF;
  background: var(--primary, #4F7CFF);
  border-radius: 20rpx;
  border-radius: var(--radius-btn, 20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(79, 124, 255, 0.32);
  box-shadow: var(--shadow-cta, 0 12rpx 32rpx rgba(79, 124, 255, 0.32));
  transition:
    background 140ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 140ms cubic-bezier(0.22, 1, 0.36, 1),
    transform 140ms cubic-bezier(0.22, 1, 0.36, 1),
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  z-index: 1;
}

.primary-btn--press {
  background: #3B63D9;
  background: var(--primary-press, #3B63D9);
  box-shadow: 0 6rpx 16rpx rgba(79, 124, 255, 0.24);
  transform: translateY(1rpx) scale(0.985);
  opacity: 0.96;
}

.primary-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1.2rpx;
}

/* ============ Stats ============ */
.stats-row {
  display: flex;
  gap: 16rpx;
  animation: fadeSlideUp 320ms cubic-bezier(0.22, 1, 0.36, 1) 180ms both;
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 180ms both;
}

.stat-card {
  flex: 1;
  background: #131A2E;
  background: var(--bg-surface-1, #131A2E);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border: 1rpx solid var(--hairline, rgba(255, 255, 255, 0.06));
  border-radius: 24rpx;
  padding: 28rpx 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-card:nth-child(2) {
  animation: fadeIn 280ms cubic-bezier(0.22, 1, 0.36, 1) 240ms both;
  animation: fadeIn 280ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 240ms both;
}

.stat-card:nth-child(3) {
  animation: fadeIn 280ms cubic-bezier(0.22, 1, 0.36, 1) 300ms both;
  animation: fadeIn 280ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 300ms both;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #F8FAFC;
  color: var(--text-strong, #F8FAFC);
  letter-spacing: 0.3rpx;
  line-height: 1.18;
}

/* Mint only when learner is doing well — small, never decorative */
.stat-num--mint {
  color: #5EEAD4;
  color: var(--aurora-mint, #5EEAD4);
}

.stat-label {
  font-size: 22rpx;
  color: #5B6884;
  color: var(--text-faint, #5B6884);
  letter-spacing: 1rpx;
}

/* ============ Path card ============ */
.path-card {
  background: rgba(15, 23, 42, 0.55);
  background: var(--bg-glass, rgba(15, 23, 42, 0.55));
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border: 1rpx solid var(--hairline, rgba(255, 255, 255, 0.06));
  border-radius: 28rpx;
  border-radius: var(--radius-card, 28rpx);
  padding: 30rpx 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  animation: fadeSlideUp 320ms cubic-bezier(0.22, 1, 0.36, 1) 240ms both;
  animation: fadeSlideUp 320ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 240ms both;
}

.path-title {
  font-size: 22rpx;
  color: #5B6884;
  color: var(--text-faint, #5B6884);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  font-weight: 600;
}

.path-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.path-item {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.path-num {
  font-size: 22rpx;
  font-weight: 600;
  color: #4F7CFF;
  color: var(--primary, #4F7CFF);
  letter-spacing: 1rpx;
  width: 44rpx;
  flex-shrink: 0;
  font-feature-settings: "tnum";
}

.path-text {
  font-size: 26rpx;
  color: #9CA8C0;
  color: var(--text-mute, #9CA8C0);
  line-height: 1.5;
  letter-spacing: 0.2rpx;
}

/* ============ Profile link (de-emphasized) ============ */
.profile-link {
  margin: 4rpx auto 0;
  padding: 18rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border-radius: var(--radius-pill, 999rpx);
  transition:
    opacity 140ms cubic-bezier(0.22, 1, 0.36, 1),
    background 140ms cubic-bezier(0.22, 1, 0.36, 1);
  animation: fadeIn 280ms cubic-bezier(0.22, 1, 0.36, 1) 320ms both;
  animation: fadeIn 280ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 320ms both;
}

.profile-link--press {
  opacity: 0.62;
  background: rgba(255, 255, 255, 0.03);
}

.profile-link-text {
  font-size: 24rpx;
  color: #5B6884;
  color: var(--text-faint, #5B6884);
  letter-spacing: 1rpx;
}

/* ============ Keyframes ============ */
@keyframes pageFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
