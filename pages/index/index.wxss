.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #222;
}

.desc {
  font-size: 28rpx;
  color: #666;
  margin-top: -18rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.stat {
  display: block;
  font-size: 28rpx;
  color: #444;
  margin-bottom: 10rpx;
}

.recommend-card {
  border: 2rpx solid #e8eefc;
}

.video-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 12rpx;
}

.video-info {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.subtitle-preview {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.secondary-btn {
  margin-top: 10rpx;
}