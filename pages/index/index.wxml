<view class="index-page">

  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="brand-group">
      <text class="brand-name">English Link</text>
      <text class="brand-badge">推荐</text>
    </view>
    <view class="stat-pill" bindtap="goMy">
      <text class="stat-pill-num">{{total > 0 ? accuracy + '%' : '--'}}</text>
      <text class="stat-pill-label">正确率</text>
    </view>
  </view>

  <!-- 全屏封面区域 -->
  <view class="cover-area">

    <!-- 背景层 -->
    <view class="cover-bg">
      <view class="cover-glow"></view>
      <!-- 视频封面卡片 -->
      <view class="cover-card" bindtap="goStudy">
        <view class="play-ring">
          <text class="play-ring-icon">▶</text>
        </view>
        <text class="cover-today-label">今日推荐</text>
      </view>
    </view>
    <view class="cover-mask"></view>

    <!-- 右侧浮动操作栏（进度 + 正确率） -->
    <view class="action-bar">
      <view class="action-item">
        <view class="action-circle">
          <text class="action-glyph action-glyph-sm">{{recommendNumber}}/{{totalVideos}}</text>
        </view>
        <text class="action-caption">进度</text>
      </view>

      <view class="action-item" bindtap="goMy">
        <view class="action-circle">
          <text class="action-glyph action-glyph-sm">{{total > 0 ? accuracy + '%' : '--'}}</text>
        </view>
        <text class="action-caption">正确率</text>
      </view>
    </view>

    <!-- 底部信息区 -->
    <view class="bottom-section">

      <!-- 文案区 -->
      <view class="bottom-text">
        <block wx:if="{{!completedAll}}">
          <view class="meta-row">
            <text class="tag scene-tag">{{todayVideo.sceneName}}</text>
            <text class="tag level-tag">{{todayVideo.level}}</text>
            <text class="tag progress-tag">{{recommendNumber}} / {{totalVideos}}</text>
          </view>
          <text class="video-title">{{todayVideo.title}}</text>
        </block>

        <block wx:else>
          <view class="meta-row">
            <text class="tag done-tag">全部完成</text>
          </view>
          <text class="video-title">本轮学习已完成</text>
        </block>
      </view>

      <!-- 按钮区 -->
      <view class="btn-area">
        <view class="start-btn" bindtap="goStudy">
          <text class="start-btn-text">{{completedAll ? '重新开始学习' : '开始推荐学习'}}</text>
        </view>
      </view>

    </view>
  </view>

  <!-- 底部导航栏：推荐 / 学习 / 我的 -->
  <view class="tab-bar">
    <view class="tab-item tab-active">
      <text class="tab-icon">✦</text>
      <text class="tab-label">推荐</text>
    </view>
    <view class="tab-item" bindtap="goStudy">
      <text class="tab-icon">▶</text>
      <text class="tab-label">学习</text>
    </view>
    <view class="tab-item" bindtap="goMy">
      <text class="tab-icon">◉</text>
      <text class="tab-label">我的</text>
    </view>
  </view>

</view>
