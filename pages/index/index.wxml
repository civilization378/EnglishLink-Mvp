<view class="index-page">

  <!-- 顶部 Hero -->
  <view class="hero">
    <view class="hero-left">
      <text class="hero-title">English Link</text>
      <text class="hero-subtitle">看真实场景，直接理解英文</text>
    </view>
    <view class="accuracy-pill" bindtap="goMy">
      <text class="accuracy-label">正确率</text>
      <text class="accuracy-num">{{total > 0 ? accuracy + '%' : '--'}}</text>
    </view>
  </view>

  <!-- 今日推荐主卡片 -->
  <view class="main-card">
    <view class="main-card-header">
      <text class="section-label">今日推荐</text>
      <text class="progress-badge">第 {{recommendNumber}} / {{totalVideos}} 条</text>
    </view>

    <block wx:if="{{!completedAll}}">
      <text class="main-card-title">{{todayVideo.title}}</text>
      <view class="tag-row">
        <text class="tag scene-tag">{{todayVideo.sceneName}}</text>
        <text class="tag level-tag">{{todayVideo.level}}</text>
      </view>
    </block>
    <block wx:else>
      <text class="main-card-title">本轮学习已完成</text>
      <view class="tag-row">
        <text class="tag done-tag">全部完成</text>
      </view>
    </block>

    <!-- 封面区域 -->
    <view class="cover-area" bindtap="goStudy">
      <view class="cover-glow"></view>
      <view class="play-ring">
        <text class="play-icon">▶</text>
      </view>
    </view>

    <!-- 开始按钮 -->
    <view class="start-btn" bindtap="goStudy">
      <text class="start-btn-text">{{completedAll ? '重新开始学习' : '开始推荐学习'}}</text>
    </view>
  </view>

  <!-- 学习统计卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{total}}</text>
      <text class="stat-label">已学习</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-card">
      <text class="stat-num">{{correct}}</text>
      <text class="stat-label">答对</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-card">
      <text class="stat-num">{{total > 0 ? accuracy + '%' : '--'}}</text>
      <text class="stat-label">正确率</text>
    </view>
  </view>

  <!-- 今日目标卡片 -->
  <view class="goal-card">
    <text class="goal-title">今日目标</text>
    <view class="goal-list">
      <view class="goal-item">
        <view class="goal-dot"></view>
        <text class="goal-text">看一段真实场景视频</text>
      </view>
      <view class="goal-item">
        <view class="goal-dot"></view>
        <text class="goal-text">理解关键英文表达</text>
      </view>
      <view class="goal-item">
        <view class="goal-dot"></view>
        <text class="goal-text">完成一道理解题</text>
      </view>
    </view>
  </view>

  <!-- 底部弱按钮 -->
  <view class="bottom-action">
    <view class="ghost-btn" bindtap="goMy">
      <text class="ghost-btn-text">查看我的学习</text>
    </view>
  </view>

</view>
