.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #222;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.content {
  color: #444;
  line-height: 1.7;
}

.next-btn {
  margin-top: 10rpx;
}