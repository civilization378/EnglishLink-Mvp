<view class="container">
  <text class="title">{{isCorrect ? '回答正确' : '回答错误'}}</text>

  <view class="card">
    <text class="label">题目</text>
    <text class="content">{{question}}</text>
  </view>

  <view class="card">
    <text class="label">解释</text>
    <text class="content">{{explanation}}</text>
  </view>

 <button bindtap="goNext" class="next-btn">
  {{hasNext ? '继续下一条' : '完成学习'}}
</button>
</view>